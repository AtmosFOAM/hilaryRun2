FoamFile
{
    format      ascii;
    class       volScalarField;
    object      epsilon;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -3 0 0 0 0];

internalField  nonuniform #codeStream
{
    codeInclude
    #{
        #include "fvMesh.H"
        #include "volFields.H"
    #};
    codeOptions
    #{
        -I$(LIB_SRC)/finiteVolume/lnInclude \
        -I$(LIB_SRC)/meshTools/lnInclude
    #};
    codeLibs
    #{
        -lmeshTools \
        -lfiniteVolume
    #};
   
    code
    #{
        // Constants to calculate epsilon
        const scalar kappa = 0.41;    // (von-Karmen's constant)
        const scalar lambdaMax = 250; // (maximum length scale)
    
        // Get the database
        const IOdictionary& d = static_cast<const IOdictionary&>(dict);
        
        // Get the mesh and create a height field
        const fvMesh& mesh = refCast<const fvMesh>(d.db());
        scalarField z = mesh.C().component(2);

        // Get the TKE
        const volScalarField& k = d.db().lookupObject<volScalarField>("k");
    
        scalarField length = 1/(1/(kappa*z) + 1/lambdaMax);

        os  << pow(k,1.5)/length;
    #};
};

boundaryField
{
    ground
    {
        type            epsilonWallFunction;
        value           uniform 0.1;
    }
    top
    {
        type            zeroGradient;
        value           uniform 0.1;
    }
    inlet
    {
        type            cyclic;
        value           uniform 0.001;
    }
    outlet
    {
        type            cyclic;
        value           uniform 0.001;
    }
    front
    {
        type           zeroGradient;
    }
    back
    {
        type           zeroGradient;
    }

    #includeEtc "caseDicts/setConstraintTypes"
}

