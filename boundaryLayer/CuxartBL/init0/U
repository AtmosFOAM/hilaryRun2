FoamFile
{
    format      ascii;
    class       volVectorField;
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (8 0 0);

boundaryField
{
    ground
    {
        type            noSlip;
        value           uniform (0 0 0);
    }

    top
    {
        type            slip;
        value           uniform (8 0 0);
    }

    inlet
    {
        type            cyclic;
        value           uniform (0 0 0);
    }

    outlet
    {
        type            cyclic;
        value           uniform (0 0 0);
    }
    front
    {
        type           zeroGradient;
    }
    back
    {
        type           zeroGradient;
    }
}

