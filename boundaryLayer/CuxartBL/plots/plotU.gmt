inputFiles=($time/U.xyz)
outFile=$time/U.eps
col=3
colx=4
#legends=(legend strings in double quotes)
#pens=(psxy pen types in double quotes)
#symbols=(psxy symbol types in double quotes) (optional)
#spens=(psxy pen types in double quotes for the symbols) (optional)
#xlabel=x label
#ylabel=y label
xmin=0
xmax=10
dx=5
ddx=1
dxg=0
ymin=0
ymax=400
dy=50
ddy=10
dyg=0
#xscale=/86400
#yscale=*1
#legPos=x10/10
nSkip=1
projection=X15c/10c
gv=1
