FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     AdImExShallowWaterFoam;

startFrom       startTime;

startTime       0;

subSolverTime   0;

stopAt          endTime;

endTime         172800; //86400; //1296000;

deltaT          3600;

writeControl    runTime;

writeInterval   3600; //43200;

purgeWrite      0;

writeFormat     binary;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable false;

libs ("libsolverFunctionObjects2.so" "libfiniteVolumeAtmosFOAM.so");

