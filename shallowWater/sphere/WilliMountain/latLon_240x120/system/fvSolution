FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

nOuterCorrs 2;
nPressureCorrs 2;
nNonOrthogCorrs 1;
timeOffCenter 0.5;

solvers
{
    "U"
    {
        solver          GAMG; //PBiCGStab; //PBiCG; //smoothSolver;
        //preconditioner  DILU;
        smoother        DILUGaussSeidel; //symGaussSeidel;
        tolerance       1e-6;
        relTol          0;
    }
    "h"
    {
        solver          GAMG; //PBiCGStab; //PBiCG; //smoothSolver;
        //preconditioner  DILU;
        smoother        symGaussSeidel;
        tolerance       1e-6;
        relTol          0;
    }
}


