type            coded;

// Load the library containing the 'coded' functionObject
libs            ("libutilityFunctionObjects.so");

name            generateT;

codeInclude
#{
    #include "mathematicalConstants.H"
    #include "volFields.H"
#};

codeWrite
#{
// A full cosine wave

    using Foam::constant::mathematical::pi;
    const dimensionedVector dx(dimless/dimLength, 2*pi*vector(1, 0, 0));
    const volScalarField x(mesh().C() & dx);

    volScalarField T
    (
        IOobject("T", mesh().time().name(), mesh()),
        0.5*(1 - Foam::cos(x))
    );
    
    T.write();
#};

