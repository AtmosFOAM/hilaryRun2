FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    T
    {
        nCorr      2;
        nSubCycles 3;

        solver          smoothSolver;
        smoother        symGaussSeidel;
        tolerance       1e-06;
        relTol          0;

        MULESCorr       yes;
        nLimiterIter    8;
        MULEStolerance  2e-4;
        applyPrevCorr  yes;
    }
}

PIMPLE
{
    nNonOrthogonalCorrectors 0;
}


