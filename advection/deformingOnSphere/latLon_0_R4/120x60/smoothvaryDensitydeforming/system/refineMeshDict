FoamFile
{
    format      ascii;
    class       dictionary;
    object      refineMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

coordinates
{
    type        patchLocal;
    patch       originalPatch;

    e1 (0 0 1);
    e2 (0 1 0);

    directions  (e1 e2);
}

zones
{
    level1
    {
        type    box;
        box     (0.5 -0.2 0.3) (1.2 0.2 0.6);
    }
}

