FoamFile
{
    format      ascii;
    class       dictionary;
    object      refineMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

coordinates
{
    type        patchLocal;
    patch       originalPatch;

    e1 (0 1 0);
    e2 (0 0 1);

    directions  (e1 e2);
}

zones
{
    level1
    {
        type    box;
        box     (-1.5 -0.5 -0.3) (-0.5 0.5 0.7);
    }
    level2
    {
        type    box;
        box     (-1.5 -0.3 -0.1) (-0.5 0.3 0.5);
    }
    level3
    {
        type    box;
        box     (-1.5 -0.2 0) (-0.5 0.2 0.4);
    }
    level4
    {
        type    box;
        box     (-1.5 -0.1 0.1) (-0.5 0.1 0.3);
    }
}

